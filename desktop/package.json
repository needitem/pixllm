{
  "name": "pixllm-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "PIXLLM desktop workbench",
  "author": "Pixoneer",
  "type": "module",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --config vite.config.ts --host 127.0.0.1 --port 4173\" \"wait-on tcp:4173 && cross-env PIXLLM_DESKTOP_DEV_SERVER_URL=http://127.0.0.1:4173 electron src/main/main.cjs\"",
    "build": "node scripts/write-build-info.mjs && vite build --config vite.config.ts && node scripts/normalize-dist-html.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "dist:win": "npm run build && electron-builder --win portable",
    "dist:portable": "npm run dist:win"
  },
  "dependencies": {
    "svelte": "^5.43.8"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.2",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.pixoneer.pixllm.desktop",
    "productName": "PIXLLM Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "src/main/**/*",
      "package.json",
      "build-info.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}

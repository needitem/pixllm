QDRANT_URL=http://qdrant:6333
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=pixllm
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=documents
PIPELINE_API_TOKEN=CHANGE_ME_32CHAR_TOKEN
API_SESSION_TOKEN=CHANGE_ME_API_SESSION_TOKEN
API_SESSION_ACCESS_ALLOW_PERMANENT=true
FRONTEND_PORT=3000
NEO4J_AUTH=neo4j/CHANGE_ME_NEO4J_PASSWORD

VLLM_URL=http://192.168.2.212:8001
# Use the official upstream Qwen model by default. If vLLM is launched with
# `--served-model-name qwen3.5-27b`, desktop clients can keep using that alias.
VLLM_MODEL=Qwen/Qwen3.5-27B
VLLM_IMAGE=vllm/vllm-openai:latest
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_USE_FP16=true
EMBEDDING_BATCH_SIZE=64

TOOL_POLICY_STRICT=true
WORKSPACE_HOST_ROOT=../
CODE_SEARCH_ROOTS=/workspace_host/pixoneer_source
IMPORT_DOCS_ROOT=/workspace_host/pixoneer_project
IMPORT_CODE_ROOT=/workspace_host/pixoneer_source
IMPORT_CODE_RESTORE_ON_START=true
SVN_BIN=svn
TF_BIN=tf
TFS_DOCS_SYNC_COMMAND=

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

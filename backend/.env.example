# ============================================================
# PIXLLM 운영 기본값 — 의사결정 문서 2026-02-26 확정
# 복사: cp .env.example .env  →  민감 값(CHANGE_ME_*)을 반드시 교체
# ============================================================

# === vLLM (LLM 서빙) ===
# 운영 노드 (A30 GPU, 192.168.2.212)
VLLM_URL=http://192.168.2.212:8001
VLLM_MODEL=Jackrong/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled
# Doc/reference-heavy fallback: comment the line above and uncomment below.
# VLLM_MODEL=qwen3.5-27b

# 검증 노드 (A30 GPU, 192.168.2.213) — 필요 시 위와 교체
# VLLM_URL=http://192.168.2.213:8001

# === 임베딩 (CPU 서빙) ===
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
EMBEDDING_USE_FP16=true
EMBEDDING_BATCH_SIZE=64

# === 외부 서비스 ===
QDRANT_URL=http://pixllm-qdrant:6333
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:${REDIS_PASSWORD}@pixllm-redis:6379/0
MINIO_ENDPOINT=pixllm-minio:9000
MINIO_ACCESS_KEY=pixllm
MINIO_SECRET_KEY=CHANGE_ME_STRONG_PASSWORD
MINIO_BUCKET=documents

# === 보안 ===
# 파이프라인 API 토큰 (32자 이상 랜덤 문자열 권장)
PIPELINE_API_TOKEN=CHANGE_ME_32CHAR_TOKEN
# 일반 API 세션 토큰 (Authorization: Bearer <token>)
API_SESSION_TOKEN=CHANGE_ME_API_SESSION_TOKEN
TOOL_POLICY_STRICT=true
TOOL_POLICY_SESSION_TTL_SEC=1800
TOOL_POLICY_SESSION_MAX_ITEMS=5000
FRONTEND_PORT=3000
NEO4J_AUTH=neo4j/CHANGE_ME_NEO4J_PASSWORD

# === Intent Classifier ===
INTENT_LLM_MAX_TOKENS=96
INTENT_LLM_TEMPERATURE=0.0
INTENT_LLM_CONFIDENCE_THRESHOLD=0.35

# === ReAct 루프 ===
CHAT_RUNTIME_MAX_TOOL_ROUNDS=3
CHAT_RUNTIME_MAX_TOOL_CALLS=8
CHAT_REACT_NATIVE_TOOL_CALLING=true
CHAT_TOOL_MAX_CHARS=5000
CHAT_TOOL_MAX_LINE_SPAN=220
CHAT_TOOL_DOC_OPEN_LIMIT=10
CHAT_TOOL_CODE_MAX_WINDOWS=12
CHAT_REACT_TIMEOUT_SEC=60
CHAT_EVIDENCE_THRESHOLD=0.4
CHAT_EVIDENCE_POLICY=ask

# === 코드 검색 ===
CODE_TOOL_ENABLED=true
CODE_SEARCH_ROOTS=/workspace_host/pixoneer_source
CODE_SEARCH_MAX_RESULTS=50
CODE_SEARCH_CONTEXT_LINES=10
CODE_SEARCH_MAX_FILE_BYTES=1500000
CODE_SEARCH_TIMEOUT_SEC=6
CODE_SEARCH_EXCLUDE_GLOBS=!.git,!node_modules,!dist,!build,!out,!vendor,!*.min.js,!*.min.css,!*.lock

# === SVN/TFS 동기화 ===
IMPORT_DOCS_ROOT=/workspace_host/pixoneer_project
IMPORT_CODE_ROOT=/workspace_host/pixoneer_source
IMPORT_CODE_RESTORE_ON_START=true
SVN_BIN=svn
TFS_DOCS_SYNC_COMMAND=

# === 대화 ===
MAX_CONVERSATION_MESSAGES=20

# === GPU 컨테이너 (docker-compose용) ===
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
